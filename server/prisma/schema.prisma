generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  login     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  password  String
  phone     String?
  telegram  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  favorites Favorite[]
  orders    Order[]
}

model Product {
  id              String    @id @default(cuid())
  name            String
  description     String?
  image           String?
  images          String[]  @default([]) // Multiple images for pod-systems (different colors)
  price           Float
  category        String
  badge           String?   // Новинка, Хит, Советуем
  showInNew       Boolean   @default(false) // Новинки и акции
  showInBestsellers Boolean @default(false) // Лидеры продаж
  // Опциональные поля фильтрации
  manufacturer    String?
  puffCount       Int?
  nicotineType    String?
  flavor          String?
  country         String?
  strength        Int?
  volume          Int?
  vgpg            String?
  charging        String?
  powerAdj        String?
  watts           String?
  resistance      String?
  battery         Int?
  supplier        String?
  tobacco         String?
  weight          String?
  coalType        String?
  packCount       String?
  color           String?
  display         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  favorites       Favorite[]
  orderItems      OrderItem[]
}

model Store {
  id       String  @id @default(cuid())
  address  String
  hours    String
  phone    String
  image    String?
  orders   Order[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, productId])
}

model Order {
  id            String    @id @default(cuid())
  userId        String?
  storeId       String
  paymentMethod String    // cash | card | qr
  status        String    @default("pending") // pending | confirmed | cancelled
  total         Float
  pickupDate    DateTime? // дата когда заберут товар
  customerName  String?
  customerPhone String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store         Store     @relation(fields: [storeId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String?
  quantity  Int     @default(1)
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model FilterOption {
  id        String   @id @default(cuid())
  category  String   // disposables | liquids | pod-systems | pouches | accessories
  filterKey String   // manufacturer | flavor | nicotineType | strength | volume | vgpg | puffCount | charging | powerAdj | battery | country | color | display
  value     String   // e.g. "HQD", "Ментол", "600"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  @@unique([category, filterKey, value])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  dateLabel   String
  teaser      String?
  description String   @db.VarChar(2500)
  image       String?
  showOnHome  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroBanner {
  id           String   @id @default(cuid())
  zone         String   // main | side-top | side-bottom
  image        String
  title        String?
  discountText String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuthCode {
  id        String   @id @default(cuid())
  code      String
  type      String   // register | password
  login     String?
  telegramId String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
